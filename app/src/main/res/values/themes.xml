<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Window-level theme used before Compose takes over. windowBackground matches the
        gradient start colour (per light/dark via @color/window_bg) so there's no flash on
        launch; system bars are transparent for edge-to-edge (icon contrast is set in code).
    -->
    <style name="Theme.HardwareOneConsole" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/window_bg</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
